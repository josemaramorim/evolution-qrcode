    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!doctype html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Conectar WhatsApp</title>\n  <style>\n    :root {\n      --bg-1: #fff7ed;\n      --bg-2: #ffedd5;\n      --ink: #111827;\n      --muted: #6b7280;\n      --accent: #ea580c;\n      --ok: #15803d;\n      --warn: #b45309;\n      --card: rgba(255, 255, 255, 0.92);\n      --stroke: rgba(17, 24, 39, 0.08);\n      --shadow: 0 20px 60px rgba(154, 52, 18, 0.18);\n    }\n    * { box-sizing: border-box; }\n    body {\n      margin: 0;\n      min-height: 100vh;\n      font-family: Segoe UI, sans-serif;\n      color: var(--ink);\n      background:\n        radial-gradient(1200px 500px at -20% -10%, rgba(234, 88, 12, 0.24), transparent 60%),\n        radial-gradient(900px 500px at 120% 110%, rgba(180, 83, 9, 0.18), transparent 50%),\n        linear-gradient(135deg, var(--bg-1), var(--bg-2));\n      display: grid;\n      place-items: center;\n      padding: 24px;\n    }\n    .panel {\n      width: min(760px, 100%);\n      background: var(--card);\n      border: 1px solid var(--stroke);\n      border-radius: 20px;\n      box-shadow: var(--shadow);\n      overflow: hidden;\n    }\n    .header {\n      padding: 24px;\n      background: linear-gradient(120deg, #7c2d12, #ea580c);\n      color: #fff;\n    }\n    .header h1 { margin: 0; font-size: clamp(1.2rem, 2.5vw, 1.7rem); }\n    .header p { margin: 10px 0 0; opacity: 0.92; line-height: 1.5; font-size: 0.98rem; }\n    .content { display: grid; gap: 20px; padding: 24px; }\n    .grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 20px; }\n    @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }\n    .card { border: 1px solid var(--stroke); border-radius: 16px; padding: 18px; background: #fff; }\n    label { display: block; margin-bottom: 8px; font-size: .92rem; color: var(--muted); font-weight: 700; }\n    input { width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 12px; font-size: 1rem; }\n    .actions { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }\n    button { border: 0; border-radius: 12px; padding: 11px 16px; font-weight: 700; cursor: pointer; }\n    .btn-primary { background: var(--accent); color: #fff; }\n    .btn-secondary { background: #f3f4f6; color: #111827; }\n    .status { min-height: 42px; border-radius: 10px; padding: 11px 12px; font-size: .95rem; line-height: 1.4; background: #f9fafb; border: 1px dashed #d1d5db; }\n    .status.ok { background: #ecfdf5; border-color: #86efac; color: var(--ok); }\n    .status.warn { background: #fffbeb; border-color: #fcd34d; color: var(--warn); }\n    .qr-wrap { display: grid; place-items: center; min-height: 280px; border-radius: 16px; border: 1px dashed #d1d5db; background: #fafafa; padding: 16px; }\n    .qr-wrap img { width: min(280px, 100%); border-radius: 10px; background: #fff; padding: 10px; border: 1px solid #e5e7eb; }\n    .muted { color: var(--muted); font-size: .9rem; margin: 0; text-align: center; }\n    .small { color: var(--muted); font-size: .84rem; margin-top: 10px; word-break: break-word; }\n  </style>\n</head>\n<body>\n  <main class=\"panel\">\n    <header class=\"header\">\n      <h1>Conectar WhatsApp</h1>\n      <p>Digite o nome da sua instancia e escaneie o QR Code para finalizar a conexao.</p>\n    </header>\n    <section class=\"content\">\n      <div class=\"grid\">\n        <article class=\"card\">\n          <label for=\"instanceName\">Nome da instancia</label>\n          <input id=\"instanceName\" type=\"text\" placeholder=\"ex.: cliente-acme\" />\n          <div class=\"actions\">\n            <button id=\"startBtn\" class=\"btn-primary\" type=\"button\">Gerar QR Code</button>\n            <button id=\"disconnectBtn\" class=\"btn-secondary\" type=\"button\">Desconectar</button>\n            <button id=\"stopBtn\" class=\"btn-secondary\" type=\"button\">Parar consulta</button>\n          </div>\n          <div id=\"status\" class=\"status\" style=\"margin-top:12px;\">Aguardando inicio da conexao.</div>\n          <p id=\"sessionMeta\" class=\"small\"></p>\n        </article>\n        <article class=\"card\">\n          <div id=\"qrWrap\" class=\"qr-wrap\">\n            <p class=\"muted\">O QR Code aparecera aqui.</p>\n          </div>\n        </article>\n      </div>\n    </section>\n  </main>\n  <script>\n    const START_ENDPOINT = \"/webhook/evolution/connect/start\";\n    const STATUS_ENDPOINT = \"/webhook/evolution/connect/status\";\n    const DISCONNECT_ENDPOINT = \"/webhook/evolution/connect/disconnect\";\n\n    const startBtn = document.getElementById(\"startBtn\");\n    const stopBtn = document.getElementById(\"stopBtn\");\n    const disconnectBtn = document.getElementById(\"disconnectBtn\");\n    const instanceInput = document.getElementById(\"instanceName\");\n    const qrWrap = document.getElementById(\"qrWrap\");\n    const statusEl = document.getElementById(\"status\");\n    const sessionMeta = document.getElementById(\"sessionMeta\");\n\n    let pollingTimer = null;\n    let currentSessionId = null;\n    let pollingPaused = false;\n\n    function setStatus(text, kind) {\n      statusEl.textContent = text;\n      statusEl.classList.remove(\"ok\", \"warn\");\n      if (kind) statusEl.classList.add(kind);\n    }\n\n    function renderQr(qrBase64) {\n      if (!qrBase64) {\n        qrWrap.innerHTML = '<p class=\"muted\">Ainda sem QR Code disponivel.</p>';\n        return;\n      }\n      const src = qrBase64.startsWith(\"data:image\") ? qrBase64 : `data:image/png;base64,${qrBase64}`;\n      qrWrap.innerHTML = `<img src=\"${src}\" alt=\"QR Code\" />`;\n    }\n\n    function stopPolling(showStatus = true) {\n      if (pollingTimer) {\n        clearInterval(pollingTimer);\n        pollingTimer = null;\n      }\n      pollingPaused = true;\n      if (showStatus) {\n        setStatus(\"Consulta pausada.\", \"warn\");\n      }\n    }\n\n    async function safeParseJson(response) {\n      const raw = await response.text();\n      if (!raw) return {};\n      return JSON.parse(raw);\n    }\n\n    async function fetchStatus() {\n      if (!currentSessionId || pollingPaused) return;\n      const response = await fetch(`${STATUS_ENDPOINT}?sessionId=${encodeURIComponent(currentSessionId)}`);\n      if (!response.ok) throw new Error(`Falha ao consultar status (${response.status}).`);\n      const data = await safeParseJson(response);\n      const state = (data.status || \"\").toLowerCase();\n\n      if (data.qrCode) {\n        renderQr(data.qrCode);\n        setStatus(\"QR Code atualizado. Escaneie com o WhatsApp.\", \"ok\");\n      }\n\n      if (state === \"connected\" || data.connected === true) {\n        setStatus(\"Conexao concluida com sucesso.\", \"ok\");\n        stopPolling(false);\n      }\n\n      if (state === \"waiting\" || state === \"qrcode\") {\n        setStatus(\"Aguardando leitura do QR Code.\", \"warn\");\n      }\n    }\n\n    async function startConnection() {\n      const instanceName = instanceInput.value.trim();\n      if (!instanceName) {\n        setStatus(\"Informe o nome da instancia.\", \"warn\");\n        return;\n      }\n\n      setStatus(\"Iniciando conexao...\", \"warn\");\n      renderQr(null);\n\n      try {\n        const response = await fetch(START_ENDPOINT, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ instanceName })\n        });\n\n        if (!response.ok) throw new Error(`Falha ao iniciar conexao (${response.status}).`);\n\n        const data = await safeParseJson(response);\n        currentSessionId = data.instanceName || data.instance?.instanceName || data.sessionId || instanceName;\n        sessionMeta.textContent = `Sessao: ${currentSessionId}`;\n\n        if (data.qrCode) {\n          renderQr(data.qrCode);\n          setStatus(\"QR Code gerado. Escaneie com o WhatsApp.\", \"ok\");\n        } else {\n          setStatus(\"Conexao iniciada. Buscando QR Code...\", \"warn\");\n        }\n\n        pollingPaused = false;\n        if (pollingTimer) clearInterval(pollingTimer);\n        pollingTimer = setInterval(() => {\n          if (pollingPaused) {\n            stopPolling(false);\n            return;\n          }\n          fetchStatus().catch(e => setStatus(e.message, \"warn\"));\n        }, 4000);\n        await fetchStatus();\n      } catch (err) {\n        setStatus(err.message || \"Erro inesperado ao iniciar conexao.\", \"warn\");\n      }\n    }\n\n    async function disconnectInstance() {\n      const instanceName = instanceInput.value.trim();\n      const sessionId = currentSessionId || instanceName;\n      if (!sessionId) {\n        setStatus(\"Informe o nome da instancia para desconectar.\", \"warn\");\n        return;\n      }\n\n      setStatus(\"Solicitando desconexao...\", \"warn\");\n\n      try {\n        const response = await fetch(DISCONNECT_ENDPOINT, {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({ sessionId, instanceName })\n        });\n\n        const data = await safeParseJson(response);\n\n        if (!response.ok && data.disconnected !== true) throw new Error(data.message || `Falha ao desconectar (${response.status}).`);\n\n        stopPolling(false);\n        currentSessionId = null;\n        renderQr(null);\n        sessionMeta.textContent = \"\";\n        setStatus(\"Instancia desconectada com sucesso.\", \"ok\");\n      } catch (err) {\n        setStatus(err.message || \"Erro inesperado ao desconectar.\", \"warn\");\n      }\n    }\n\n    startBtn.addEventListener(\"click\", startConnection);\n    disconnectBtn.addEventListener(\"click\", disconnectInstance);\n    stopBtn.addEventListener(\"click\", stopPolling);\n  </script>\n</body>\n</html>",
