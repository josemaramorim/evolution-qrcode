    {
      "parameters": {
        "jsCode": "const base64 = $json.base64 || null;\nconst state = ($json.instance?.state || $json.state || '').toLowerCase();\nconst httpStatus = $json.status;\nconst message = ($json.message || '').toLowerCase();\n\n// Connected: state is open/connected OR Evolution API returned 403 (already connected)\nconst isConnected = state === 'open' || state === 'connected'\n  || (httpStatus === 403 && message.includes('connect'));\n\nreturn [{\n  json: {\n    status: isConnected ? 'connected' : (base64 ? 'qrcode' : state || 'waiting'),\n    connected: isConnected,\n    qrCode: isConnected ? null : base64\n  }\n}];"
